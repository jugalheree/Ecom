# ── Server ────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tradesphere

# ── JWT — generate with: openssl rand -hex 64 ────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret_min_64_chars_random
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_64_chars_random
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Cloudinary ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Ola Maps ─────────────────────────────────────────────────────────────
OLA_MAPS_API_KEY=your_ola_maps_api_key

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Leave blank in development — emails will be logged to console instead
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=TradeSphere <noreply@yourdomain.com>

# ── Referral Rewards ──────────────────────────────────────────────────────
REFERRAL_BONUS_REFERRER=100
REFERRAL_BONUS_REFEREE=50
