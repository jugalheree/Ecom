# ── API Base URL ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Ola Maps (Address Autocomplete) ───────────────────────────────────────
# Get your API key from: https://maps.olakrutrim.com/
# Required for address search in Checkout, Profile, and Vendor Setup.
# The app works without it — users can fill addresses manually.
VITE_OLA_MAPS_API_KEY=your_ola_maps_api_key_here
