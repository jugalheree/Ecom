# ── Production Environment Variables ─────────────────────────────────────
# Copy this to .env.production and fill in real values

# Your deployed backend API URL (no trailing slash)
VITE_API_BASE_URL=https://api.yourdomain.com

# Ola Maps API key for address autocomplete
# Get from: https://maps.olakrutrim.com/
# App works without this — users can type addresses manually
VITE_OLA_MAPS_API_KEY=your_ola_maps_api_key_here
